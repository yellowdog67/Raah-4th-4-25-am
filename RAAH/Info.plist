<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleDisplayName</key>
	<string>RAAH</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>location</string>
	</array>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>RAAH uses your location to tell you about nearby places, landmarks, and hidden stories as you walk.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>RAAH uses your location in the background to provide safety alerts and continuous guidance.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>RAAH needs your microphone for voice conversations with your AI travel companion.</string>
	<key>NSCameraUsageDescription</key>
	<string>RAAH uses the camera for Snap &amp; Ask — point at anything and your AI will tell you about it.</string>
	<key>NSHealthShareUsageDescription</key>
	<string>RAAH reads your heart rate to make the orb pulse with your rhythm. This is optional.</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.raah.deeplink</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>raah</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
